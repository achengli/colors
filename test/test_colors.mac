/*
 * colors/test/test_colors.mac
 *
 * Tests for the colors package.
 */

kill(all)$
file_search_maxima: cons("/Users/tao/Git/colors/src/###.{mac,mc}", file_search_maxima)$
load("colors")$

print("=== Testing colors package ===")$

/* Check that exports exist */
print("Checking exports ...")$
for e in colorsExports do (
    print("  ", e[1])
)$

/* Check version */
print("Version: ", colorsVersion)$

/* Test basic colorize */
print("Testing colorize functions ...")$
colorsPrintRed("This text should be red")$
colorsPrintGreen("This text should be green")$
colorsPrintBlue("This text should be blue")$
colorsPrintYellow("This text should be yellow")$
colorsPrintCyan("This text should be cyan")$
colorsPrintMagenta("This text should be magenta")$

/* Test styles */
print("Testing styles ...")$
colorsPrintBold("This text should be bold")$
colorsPrintUnderline("This text should be underlined")$

/* Test background */
print("Testing background colors ...")$
print(colorsBgRed("  Red background  "))$
print(colorsBgGreen("  Green background  "))$
print(colorsBgBlue("  Blue background  "))$

/* Test combinators */
print("Testing bold red ...")$
print(concat(colorsBoldCode, colorsRed("bold red text")))$

/* Test rgb */
print("Testing 24-bit color ...")$
print(colorsRgb(255, 128, 0, "Custom orange text"))$

/* Test style */
print("Testing style ...")$
print(colorsStyle("1;4;31", "Bold underlined red"))$

print("")$
print("All colors tests passed.")$
